{
  "name": "collegefinance",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "nodemon --watch main.js --watch index.html --watch style.css --exec npx electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.yourname.collegefinance",
    "productName": "College Finance Tracker",
    "files": [
      "**/*",
      "!dist/**"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
